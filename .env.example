# ═══════════════════════════════════════════════════════════════
# Polymarket Weather Bot — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# HOW TO GET YOUR CREDENTIALS:
# 1. Go to https://polymarket.com and log in
# 2. Export your private key from https://reveal.polymarket.com
# 3. Your funder address = your Polymarket profile address
#    (visible in URL: polymarket.com/profile/<THIS_ADDRESS>)
#    ⚠️  This is NOT your MetaMask deposit address!
# ═══════════════════════════════════════════════════════════════

# Your Polymarket private key (from reveal.polymarket.com)
POLYMARKET_PRIVATE_KEY=0x...

# Your Polymarket proxy wallet address (from your profile URL)
# ⚠️  NOT your MetaMask/deposit address — the address in your profile URL
POLYMARKET_FUNDER_ADDRESS=0x...

# Signature type:
#   0 = EOA (direct wallet, needs POL for gas)
#   1 = POLY_PROXY (Magic Link / email login — export PK from Polymarket)
#   2 = GNOSIS_SAFE (browser wallet like MetaMask — most common)
POLYMARKET_SIGNATURE_TYPE=2

# Starting bankroll in USDC (how much you want to trade with)
POLYMARKET_BANKROLL=50.0

# Optional: Geo token for restricted regions
# POLYMARKET_GEO_TOKEN=

# ═══════════════════════════════════════════════════════════════
# BUILDER API (optional but recommended)
# ═══════════════════════════════════════════════════════════════
# Enables gasless trading (no POL needed) + order attribution for
# weekly USDC liquidity rewards. Free signup:
#   https://polymarket.com/settings?tab=builder
#
# After creating your Builder API key, fill in:
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# Order strategy: "adaptive" (default), "maker", or "taker"
# - adaptive: post-only for small edges (<15%), aggressive for big edges
# - maker: always post-only (earns liquidity rewards, slower fills)
# - taker: always aggressive (instant fills, no rewards)
ORDER_STRATEGY=adaptive
