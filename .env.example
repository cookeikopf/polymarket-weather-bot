# Polymarket Weather Bot V6 — Environment Configuration
# Copy this to .env and fill in your values

# ─── Polymarket (required for live trading) ───
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here
POLYMARKET_FUNDER_ADDRESS=0x_your_funder_address_here
POLYMARKET_SIGNATURE_TYPE=2
POLYMARKET_BANKROLL=100

# ─── Builder API (optional, enables gasless trading) ───
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# ─── Open-Meteo (recommended, commercial tier) ───
OPEN_METEO_API_KEY=

# ─── Order strategy: taker | maker | adaptive ───
ORDER_STRATEGY=adaptive
